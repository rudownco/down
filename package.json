{
  "name": "down-monorepo",
  "private": true,
  "workspaces": [
    "common",
    "down",
    "web"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:mobile": "npm run start --workspace=down",
    "build:web": "npm run build --workspace=web",
    "build:common": "npm run build --workspace=common",
    "sync:shared": "tsx scripts/sync-permissions.ts",
    "check:shared": "tsx scripts/sync-permissions.ts --check",
    "test:backend": "npm run test --prefix backend"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
